{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_note": "Example settings used by CI to validate boot-validation.ps1 against a known-good wired config. Do NOT use directly — copy to settings.json and customize permissions.",
  "permissions": {
    "allow": ["Read(*)", "Write(*)", "Edit(*)"],
    "deny": ["Task"]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File ${CLAUDE_PROJECT_DIR}/.claude/hooks/boot-validation.ps1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File ${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-bash.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File ${CLAUDE_PROJECT_DIR}/.claude/hooks/post-tool.ps1"
          }
        ]
      }
    ]
  },
  "env": {
    "MORTY_DENYLIST":     "${CLAUDE_PROJECT_DIR}/.claude/skills/safe-bash/references/denylist.yaml",
    "MORTY_MODEL":        "user.Qwen3.6-30B-A3B-GGUF",
    "MORTY_PROJECT_ROOT": "${CLAUDE_PROJECT_DIR}"
  }
}
